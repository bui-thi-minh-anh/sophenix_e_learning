      "exercises": [
        {
          "id": "cm1",
          "kind": "mcq",
          "question": "Từ \"burglar\" nghĩa là gì?",
          "options": [
            {
              "key": "A",
              "text": "kẻ cướp có vũ khí"
            },
            {
              "key": "B",
              "text": "kẻ trộm đột nhập vào nhà"
            },
            {
              "key": "C",
              "text": "kẻ trộm trong cửa hàng"
            },
            {
              "key": "D",
              "text": "nghi phạm"
            }
          ],
          "answer": "B",
          "explanation": "burglar = kẻ trộm đột nhập vào nhà/tòa nhà"
        },
        {
          "id": "cm2",
          "kind": "mcq",
          "question": "Người làm chứng cho một vụ việc gọi là gì?",
