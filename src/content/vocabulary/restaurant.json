        { "id": "rm10", "kind": "mcq", "question": "\"fluffy\" thường dùng để miêu tả…", "options": [ { "key": "A", "text": "bánh xốp, mềm nhẹ" }, { "key": "B", "text": "thịt dai" }, { "key": "C", "text": "rau giòn" }, { "key": "D", "text": "nước sốt mặn" } ], "answer": "A", "explanation": "fluffy = xốp, nhẹ" },
        { "id": "rm11", "kind": "mcq", "question": "Từ nào KHÔNG phải là cách chế biến (nấu)?", "options": [ { "key": "A", "text": "bake" }, { "key": "B", "text": "roast" }, { "key": "C", "text": "receipt" }, { "key": "D", "text": "boil" } ], "answer": "C", "explanation": "receipt = biên lai (không phải cách nấu)" },
        { "id": "rm12", "kind": "mcq", "question": "\"savory\" trái nghĩa gần nhất với…", "options": [ { "key": "A", "text": "sweet (ngọt)" }, { "key": "B", "text": "crispy (giòn)" }, { "key": "C", "text": "juicy (mọng nước)" }, { "key": "D", "text": "tender (mềm)" } ], "answer": "A", "explanation": "savory = đậm vị/mặn, trái với sweet = ngọt" },
        { "id": "rm13", "kind": "mcq", "question": "Từ nào có nghĩa là \"biên lai\"?", "options": [ { "key": "A", "text": "bill" }, { "key": "B", "text": "receipt" }, { "key": "C", "text": "menu" }, { "key": "D", "text": "order" } ], "answer": "B", "explanation": "receipt = biên lai; bill = hóa đơn" },
        { "id": "rm14", "kind": "mcq", "question": "\"umami\" là loại vị…", "options": [ { "key": "A", "text": "chua" }, { "key": "B", "text": "cay" }, { "key": "C", "text": "vị ngọt thịt (umami)" }, { "key": "D", "text": "đắng" } ], "answer": "C", "explanation": "umami = vị umami (vị ngọt thịt đậm đà)" },
