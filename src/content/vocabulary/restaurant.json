        { "id": "rm5", "kind": "mcq", "question": "Cách nấu nào là \"hấp\"?", "options": [ { "key": "A", "text": "boil" }, { "key": "B", "text": "steam" }, { "key": "C", "text": "grill" }, { "key": "D", "text": "roast" } ], "answer": "B", "explanation": "steam = hấp" },
        { "id": "rm6", "kind": "mcq", "question": "\"grill\" nghĩa là gì?", "options": [ { "key": "A", "text": "luộc" }, { "key": "B", "text": "nướng lò" }, { "key": "C", "text": "nướng vỉ" }, { "key": "D", "text": "quay" } ], "answer": "C", "explanation": "grill = nướng (vỉ)" },
