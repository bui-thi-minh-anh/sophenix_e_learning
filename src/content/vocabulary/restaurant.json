        { "id": "rm8", "kind": "mcq", "question": "Bạn để lại \"a tip\" nghĩa là bạn để lại…", "options": [ { "key": "A", "text": "tiền boa" }, { "key": "B", "text": "biên lai" }, { "key": "C", "text": "thực đơn" }, { "key": "D", "text": "món tráng miệng" } ], "answer": "A", "explanation": "tip = tiền boa" },
