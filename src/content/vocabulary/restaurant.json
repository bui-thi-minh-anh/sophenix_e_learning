        { "id": "rm2", "kind": "mcq", "question": "Từ nào có nghĩa là \"món khai vị\"?", "options": [ { "key": "A", "text": "dessert" }, { "key": "B", "text": "main course" }, { "key": "C", "text": "appetizer" }, { "key": "D", "text": "menu" } ], "answer": "C", "explanation": "appetizer = món khai vị" },
        { "id": "rm3", "kind": "mcq", "question": "\"The steak is tender\" nghĩa là miếng bít tết…", "options": [ { "key": "A", "text": "giòn" }, { "key": "B", "text": "mềm" }, { "key": "C", "text": "cứng" }, { "key": "D", "text": "mặn" } ], "answer": "B", "explanation": "tender = mềm (thịt)" },
