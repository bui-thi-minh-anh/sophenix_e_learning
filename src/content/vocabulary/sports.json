        { "id": "spf11", "kind": "fill", "question": "A good ___ helps the players improve their skills.", "answer": "coach", "acceptable": [], "explanation": "coach = huấn luyện viên" },
        { "id": "spf12", "kind": "fill", "question": "His ___ in the final was faster and stronger than him.", "answer": "opponent", "acceptable": [], "explanation": "opponent = đối thủ" },
