        { "id": "spm7", "kind": "mcq", "question": "Từ nào có nghĩa là \"huy chương\"?", "options": [ { "key": "A", "text": "medal" }, { "key": "B", "text": "goal" }, { "key": "C", "text": "score" }, { "key": "D", "text": "race" } ], "answer": "A", "explanation": "medal = huy chương" },
        { "id": "spm8", "kind": "mcq", "question": "\"stretch\" nghĩa là gì?", "options": [ { "key": "A", "text": "chạy nhanh" }, { "key": "B", "text": "giãn cơ" }, { "key": "C", "text": "ném bóng" }, { "key": "D", "text": "cổ vũ" } ], "answer": "B", "explanation": "stretch = giãn cơ" },
